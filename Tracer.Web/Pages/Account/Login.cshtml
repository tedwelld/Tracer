@page
@model Tracer.Web.Pages.Account.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tracer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <main class="login-shell">
        <section class="login-card">
            <p class="eyebrow">Admin Access</p>
            <h1>Sign in to Tracer</h1>
            <p class="hero-text">Only the seeded administrator account can access device data and management pages.</p>

            <form method="post" class="login-form">
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <label class="login-field">
                    <span>Username</span>
                    <input asp-for="Input.UserName" autocomplete="username" class="form-input" />
                    <span asp-validation-for="Input.UserName" class="field-validation-error"></span>
                </label>

                <label class="login-field">
                    <span>Password</span>
                    <input asp-for="Input.Password" autocomplete="current-password" class="form-input" />
                    <span asp-validation-for="Input.Password" class="field-validation-error"></span>
                </label>

                <label class="login-remember">
                    <input asp-for="Input.RememberMe" />
                    <span>Keep me signed in on this browser</span>
                </label>

                <button type="submit" class="button-primary login-submit">Sign in</button>
            </form>
        </section>
    </main>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
