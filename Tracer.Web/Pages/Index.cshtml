@page
@model IndexModel
@{
    ViewData["Title"] = "Tracer Dashboard";

    var radioDistribution = Model.Dashboard.RadioDistribution;
    var connectivity = Model.Dashboard.ConnectivityBreakdown;
    var activePercent = connectivity.TotalCount == 0 ? 0 : connectivity.ActiveCount * 100d / connectivity.TotalCount;
    var quietPercent = connectivity.TotalCount == 0 ? 0 : connectivity.QuietCount * 100d / connectivity.TotalCount;
    var quietStop = activePercent + quietPercent;
    var donutBackground = connectivity.TotalCount == 0
        ? "radial-gradient(circle, rgba(8, 26, 35, 0.94) 58%, transparent 59%), conic-gradient(rgba(159, 192, 182, 0.18) 0 100%)"
        : FormattableString.Invariant($"radial-gradient(circle, rgba(8, 26, 35, 0.94) 58%, transparent 59%), conic-gradient(var(--accent) 0% {activePercent:0.##}%, var(--warn) {activePercent:0.##}% {quietStop:0.##}%, var(--danger) {quietStop:0.##}% 100%)");
    var wifiBarHeight = FormattableString.Invariant($"height:{(radioDistribution.WifiCount * 100d / radioDistribution.MaxCount):0.##}%");
    var bluetoothBarHeight = FormattableString.Invariant($"height:{(radioDistribution.BluetoothCount * 100d / radioDistribution.MaxCount):0.##}%");
}

<section class="hero-panel">
    <div class="hero-copy">
        <p class="eyebrow">Tracer</p>
        <h1>Local Wi-Fi and Bluetooth watch console</h1>
        <p class="hero-text">
            Continuous scans run in the worker service, discoveries are stored in SQL Server 2022,
            and the dashboard highlights recent scan activity across the environment.
        </p>
    </div>
    <div class="hero-stats">
        <article class="stat-card">
            <span class="stat-label">Tracked devices</span>
            <strong>@Model.Dashboard.TotalTrackedDevices</strong>
        </article>
        <article class="stat-card">
            <span class="stat-label">Pending alerts</span>
            <strong>@Model.Dashboard.PendingAlertCount</strong>
        </article>
        <article class="stat-card">
            <span class="stat-label">Total observations</span>
            <strong>@Model.Dashboard.TotalObservations</strong>
        </article>
    </div>
</section>

<section class="insights-grid">
    <article class="panel chart-panel">
        <div class="panel-header">
            <div>
                <h2>Collection Mix</h2>
                <span class="panel-kicker">Tracked device totals</span>
            </div>
            <span class="chart-total">@radioDistribution.TotalCount devices</span>
        </div>
        <div class="bar-chart">
            <article class="bar-column">
                <span class="bar-value">@radioDistribution.WifiCount</span>
                <div class="bar-track">
                    <div class="bar-fill bar-fill-wifi" style="@wifiBarHeight"></div>
                </div>
                <span class="bar-label">Wi-Fi</span>
            </article>
            <article class="bar-column">
                <span class="bar-value">@radioDistribution.BluetoothCount</span>
                <div class="bar-track">
                    <div class="bar-fill bar-fill-bluetooth" style="@bluetoothBarHeight"></div>
                </div>
                <span class="bar-label">Bluetooth</span>
            </article>
        </div>
    </article>

    <article class="panel chart-panel">
        <div class="panel-header">
            <div>
                <h2>Connectivity Status</h2>
                <span class="panel-kicker">All devices by last seen activity</span>
            </div>
            <span class="chart-total">@connectivity.TotalCount devices</span>
        </div>
        <div class="donut-layout">
            <div class="donut-chart" style="background:@donutBackground">
                <div class="donut-center">
                    <strong>@connectivity.TotalCount</strong>
                    <span>devices</span>
                </div>
            </div>
            <div class="legend-list">
                <article class="legend-item">
                    <span class="legend-swatch legend-swatch-active"></span>
                    <div>
                        <strong>Active</strong>
                        <span>Seen within 15 minutes</span>
                    </div>
                    <span>@connectivity.ActiveCount</span>
                </article>
                <article class="legend-item">
                    <span class="legend-swatch legend-swatch-quiet"></span>
                    <div>
                        <strong>Quiet</strong>
                        <span>Seen within 1 hour</span>
                    </div>
                    <span>@connectivity.QuietCount</span>
                </article>
                <article class="legend-item">
                    <span class="legend-swatch legend-swatch-offline"></span>
                    <div>
                        <strong>Offline</strong>
                        <span>No recent activity</span>
                    </div>
                    <span>@connectivity.OfflineCount</span>
                </article>
            </div>
        </div>
        <p class="dashboard-note">Connectivity is inferred from each device's latest observation timestamp so both Wi-Fi and Bluetooth are measured consistently.</p>
    </article>
</section>

<section class="dashboard-grid dashboard-grid-single">
    <article class="panel latest-scan-panel">
        <div class="panel-header">
            <h2>Latest scan</h2>
            <span class="panel-kicker">Background worker</span>
        </div>
        @if (Model.Dashboard.LatestScan is null)
        {
            <p class="muted">No scans have been persisted yet. Start the worker and refresh this page.</p>
        }
        else
        {
            <dl class="metrics">
                <div>
                    <dt>Completed</dt>
                    <dd>@Model.Dashboard.LatestScan.CompletedUtc.ToLocalTime().ToString("g")</dd>
                </div>
                <div>
                    <dt>Scanner node</dt>
                    <dd>@Model.Dashboard.LatestScan.ScannerNode</dd>
                </div>
                <div>
                    <dt>Total</dt>
                    <dd>@Model.Dashboard.LatestScan.TotalDevices</dd>
                </div>
                <div>
                    <dt>Wi-Fi</dt>
                    <dd>@Model.Dashboard.LatestScan.WifiDevices</dd>
                </div>
                <div>
                    <dt>Bluetooth</dt>
                    <dd>@Model.Dashboard.LatestScan.BluetoothDevices</dd>
                </div>
            </dl>
        }
    </article>
</section>

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>Recent devices</h2>
            <span class="panel-kicker">Latest 5 observations</span>
        </div>
        <form method="get" class="dashboard-filter-form">
            <label class="dashboard-filter-field">
                <span>Name</span>
                <input type="text" name="SearchName" value="@Model.SearchName" class="form-input dashboard-filter-input" placeholder="Device name or address" />
            </label>
            <label class="dashboard-filter-field">
                <span>Date</span>
                <input type="date" name="SearchDate" value="@(Model.SearchDate?.ToString("yyyy-MM-dd"))" class="form-input dashboard-filter-input" />
            </label>
            <div class="dashboard-filter-actions">
                <button type="submit" class="button-primary">Filter</button>
                <a asp-page="/Index" class="button-secondary">Clear</a>
            </div>
        </form>
    </div>
    <div class="table-wrap">
        @if (Model.Dashboard.RecentDevices.Count == 0)
        {
            <p class="muted">No devices matched the current filters.</p>
        }
        else
        {
            <table class="device-table">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Device</th>
                        <th>Address</th>
                        <th>Security</th>
                        <th>Signal</th>
                        <th>Status</th>
                        <th>Last seen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var device in Model.Dashboard.RecentDevices)
                    {
                        <tr>
                            <td>@device.RadioKind</td>
                            <td>@device.Label</td>
                            <td>@(device.HardwareAddress ?? "-")</td>
                            <td>@(device.SecurityType ?? "-")</td>
                            <td>@(device.SignalStrength?.ToString() ?? "-")</td>
                            <td>
                                <span class="pill @(device.IsKnown ? "pill-known" : "pill-alert")">
                                    @(device.IsKnown ? "Trusted" : "Unknown")
                                </span>
                                @if (device.IsPaired)
                                {
                                    <span class="pill pill-paired">Paired</span>
                                }
                            </td>
                            <td>@device.LastSeenUtc.ToLocalTime().ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</section>
