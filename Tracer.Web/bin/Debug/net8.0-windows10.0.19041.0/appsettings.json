{
  "ConnectionStrings": {
    "TracerDb": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=TracerDb;MultipleActiveResultSets=true;TrustServerCertificate=true;"
  },
  "Scanner": {
    "EnableWifi": true,
    "EnableBluetooth": true,
    "ScanIntervalSeconds": 30,
    "ApproximateRangeMeters": 20,
    "WifiScanTimeoutSeconds": 8,
    "MinimumWifiSignalQuality": 15
  },
  "Alerts": {
    "CreateAlertsForUnknownDevices": true,
    "ReturnAlertThresholdMinutes": 120
  },
  "OuiVendor": {
    "EnableRemoteRefresh": true,
    "DownloadUrl": "https://standards-oui.ieee.org/oui/oui.csv",
    "RefreshIntervalDays": 7
  },
  "Notifications": {
    "Email": {
      "Enabled": false,
      "Host": "",
      "Port": 587,
      "UseSsl": true,
      "UserName": "",
      "Password": "",
      "SenderAddress": "",
      "SenderDisplayName": "Tracer",
      "ToAddresses": []
    },
    "Webhook": {
      "Enabled": false,
      "Url": "",
      "SharedSecret": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
